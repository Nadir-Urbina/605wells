rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to get team member auth data
    function getTeamMemberAuth() {
      return get(/databases/$(database)/documents/teamMemberAuth/$(request.auth.uid)).data;
    }

    // Team Member Auth Collection
    // Team members can only read their own auth record
    match /teamMemberAuth/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;
      allow write: if false; // Only server (Admin SDK) can write
    }

    // Bookings Collection
    // Team members can read bookings where they are assigned
    // Only server (Admin SDK) can create/update bookings
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() &&
                     resource.data.teamMemberId == getTeamMemberAuth().sanityTeamMemberId;
      allow write: if false; // Only server (Admin SDK) can write
    }

    // Queue Entries Collection
    // Team members cannot access queue (admin only via Admin SDK)
    match /queueEntries/{queueId} {
      allow read, write: if false; // Only server (Admin SDK) can access
    }

    // Availability Collection
    // Team members can read/write their own availability
    match /availability/{availabilityId} {
      allow read: if isAuthenticated() &&
                     resource.data.teamMemberId == getTeamMemberAuth().sanityTeamMemberId;

      allow create: if isAuthenticated() &&
                       request.resource.data.teamMemberId == getTeamMemberAuth().sanityTeamMemberId;

      allow update: if isAuthenticated() &&
                       resource.data.teamMemberId == getTeamMemberAuth().sanityTeamMemberId &&
                       request.resource.data.teamMemberId == resource.data.teamMemberId;

      allow delete: if isAuthenticated() &&
                       resource.data.teamMemberId == getTeamMemberAuth().sanityTeamMemberId;
    }

    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
